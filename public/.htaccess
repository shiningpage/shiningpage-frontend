<IfModule mod_rewrite.c>
  RewriteEngine On

  # اگر مسیر با /en یا /fa یا /ar شروع میشه، حذفش کن
  RewriteCond %{REQUEST_URI} ^/(en|fa|ar)(/.*)?$ [NC]
  RewriteRule ^(en|fa|ar)(/.*)?$ %2 [R=301,L,NE]

  # Redirect parmisbeauty.ir and www.parmisbeauty.ir to new URL
  RewriteCond %{HTTP_HOST} ^(www\.)?parmisbeauty\.ir$ [NC]
  RewriteRule ^(.*)$ https://shiningpage.com/publisher/parmis_beauty [R=301,L]

  # Redirect asooparts.ir and www.asooparts.ir to new URL
  RewriteCond %{HTTP_HOST} ^(www\.)?asooparts\.ir$ [NC]
  RewriteRule ^(.*)$ https://shiningpage.com/publisher/asooparts [R=301,L]

  # Redirect mahooryadak.ir and www.mahooryadak.ir to new URL
  RewriteCond %{HTTP_HOST} ^(www\.)?mahooryadak\.ir$ [NC]
  RewriteRule ^(.*)$ https://shiningpage.com/publisher/mahooryadak [R=301,L]

  # Redirect marisaarts.ir and www.marisaarts.ir to new URL
  RewriteCond %{HTTP_HOST} ^(www\.)?marisaarts\.ir$ [NC]
  RewriteRule ^(.*)$ https://shiningpage.com/publisher/marisaarts [R=301,L]

  # Redirect shahlaskincare.com and www.shahlaskincare.com to new URL
  RewriteCond %{HTTP_HOST} ^(www\.)?shahlaskincare\.com$ [NC]
  RewriteRule ^(.*)$ https://shiningpage.com/publisher/shahlaskincare [R=301,L]

  # Redirect lilibeat.com and www.lilibeat.com to new URL
  RewriteCond %{HTTP_HOST} ^(www\.)?lilibeat\.com$ [NC]
  RewriteRule ^(.*)$ https://shiningpage.com/publisher/lilibeat [R=301,L]

</IfModule>

# Force HTTPS and WWW
RewriteEngine On

# Redirect to HTTPS if not already HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://www.shiningpage.com/$1 [L,R=301]

# Redirect to WWW if not already WWW
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.shiningpage.com/$1 [L,R=301]

# Allow access to index.html directly
RewriteRule ^index\.html$ - [L]

# Redirect all other requests to index.html if not a file or directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^.*$ /index.html [L]